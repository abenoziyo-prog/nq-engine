# Copy this file to `.env` and fill in. `.env` is gitignored; keys NEVER commit.
# ACTIVE execution venue: IBKR paper (see IBKR_* block below). Tradovate kept as
# a fallback venue.
#
# ── Interactive Brokers DEMO (== "paper trading") ────────────────────────────
# There is no API key — "auth" is a socket to a running TWS or IB Gateway session.
#
# HOW TO GET THEM:
#   1. Activate a free IBKR paper-trading account (paper acct id is prefixed "DU").
#   2. Run TWS or IB Gateway logged into the PAPER account; in API settings enable
#      "ActiveX and Socket Clients".
#   3. PORT must be a PAPER port: TWS paper = 7497, IB Gateway paper = 4002.
#      Live ports (7496 / 4001) are HARD-REFUSED by the client.
#   4. ACCOUNT must be the paper account id (DU#######). Non-"DU" ids are refused.
#   5. CLIENT_ID is any stable integer unique per connecting app.
#
# Until ACCOUNT (DU*) + a paper PORT are set, the bridge stays in DRY_RUN (no
# socket, no orders). Even once set, live placement is gated behind T18 (verified
# paper-Gateway handshake) — nothing routes to the paper account until enabled.

IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=7
IBKR_ACCOUNT=

# ── Tradovate DEMO credentials (fallback venue) ──────────────────────────────
#
# HOW TO GET THEM (free, ~5 min):
#   1. Create a free Tradovate DEMO/simulation account at tradovate.com.
#   2. In the Tradovate app: Application Settings -> API Access -> request API access
#      (free for demo). This issues your API key pair: cid + sec.
#   3. NAME/PASSWORD are your Tradovate login. DEVICE_ID is any stable string you choose.
#   4. APP_ID/APP_VERSION are your app label (any non-empty values for demo).
#
# Until these are set, the bridge stays in DRY_RUN (no network, no orders).
# Even once set, live placement is gated behind T18 (verified demo handshake) —
# nothing routes to the demo account until that is deliberately enabled.

TRADOVATE_NAME=
TRADOVATE_PASSWORD=
TRADOVATE_APP_ID=nq-engine
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CID=
TRADOVATE_SEC=
TRADOVATE_DEVICE_ID=nq-engine-bridge

# Edgeful API (read-only stats). Bearer auth; base https://api.edgeful.com
# Get from your Edgeful account. NOTE: NQ + most reports require a paid Pro/All-Access
# plan; the starter tier only exposes RTY + {previous-days-range, opening-stats,
# green-and-red-days-by-weekday}. Used only to cross-check our own NQ reproductions.
EDGEFUL_API_KEY=
