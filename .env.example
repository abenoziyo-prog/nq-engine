# Tradovate DEMO credentials — copy this file to `.env` and fill in.
# `.env` is gitignored; these keys NEVER get committed.
#
# HOW TO GET THEM (free, ~5 min):
#   1. Create a free Tradovate DEMO/simulation account at tradovate.com.
#   2. In the Tradovate app: Application Settings -> API Access -> request API access
#      (free for demo). This issues your API key pair: cid + sec.
#   3. NAME/PASSWORD are your Tradovate login. DEVICE_ID is any stable string you choose.
#   4. APP_ID/APP_VERSION are your app label (any non-empty values for demo).
#
# Until these are set, the bridge stays in DRY_RUN (no network, no orders).
# Even once set, live placement is gated behind T18 (verified demo handshake) —
# nothing routes to the demo account until that is deliberately enabled.

TRADOVATE_NAME=
TRADOVATE_PASSWORD=
TRADOVATE_APP_ID=nq-engine
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CID=
TRADOVATE_SEC=
TRADOVATE_DEVICE_ID=nq-engine-bridge

# Edgeful API (read-only stats). Bearer auth; base https://api.edgeful.com
# Get from your Edgeful account. NOTE: NQ + most reports require a paid Pro/All-Access
# plan; the starter tier only exposes RTY + {previous-days-range, opening-stats,
# green-and-red-days-by-weekday}. Used only to cross-check our own NQ reproductions.
EDGEFUL_API_KEY=
